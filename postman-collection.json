                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"admin@blindzy.com\",\n  \"password\": \"admin123456\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/admin/auth",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "auth"]
                },
                "description": "Login and get admin token"
