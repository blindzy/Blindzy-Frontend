                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Premium Roller Blind\",\n  \"description\": \"High-quality roller blind with multiple customization options\",\n  \"base_price\": 149.99,\n  \"type\": \"Roller\",\n  \"product_image_url\": \"https://example.com/roller-blind.jpg\",\n  \"customization_options\": [\n    {\n      \"option_name\": \"Color\",\n      \"input_type\": \"select\",\n      \"required\": true,\n      \"choices\": [\n        {\n          \"choice_label\": \"White\",\n          \"choice_value\": \"white\",\n          \"price_modifier\": 0,\n          \"is_default\": true\n        },\n        {\n          \"choice_label\": \"Black\",\n          \"choice_value\": \"black\",\n          \"price_modifier\": 10.00\n        }\n      ]\n    },\n    {\n      \"option_name\": \"Size\",\n      \"input_type\": \"select\",\n      \"required\": true,\n      \"choices\": [\n        {\n          \"choice_label\": \"Small (60x120cm)\",\n          \"choice_value\": \"small\",\n          \"price_modifier\": 0,\n          \"is_default\": true\n        },\n        {\n          \"choice_label\": \"Large (120x180cm)\",\n          \"choice_value\": \"large\",\n          \"price_modifier\": 50.00\n        }\n      ]\n    }\n  ]\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/admin/products/custom_product",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "products", "custom_product"]
                },
                "description": "Create a custom product with customization options"
