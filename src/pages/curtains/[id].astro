---
import Layout from "@layouts/Layout.astro";
import Navbar from "@components/navbar/navbar";
import Footer from "@components/Footer/Footer";
import Single_curtain_customization from "@components/customization/single-curtain-customization";
import fetchMedusaApi from "@lib/lib/fetchMedusaApi";
import fetchApi from "@lib/strapi";
import type { GroupData } from "@interfaces/interfaces";

async function getData() {
  const groupData = await fetchApi<GroupData>({
    endpoint: "curtain-price?populate=*",
    wrappedByKey: "data",
  });
  return { groupData };
}
const { groupData } = await getData();

const { id } = Astro.params;

// Fetch full product data at render time
const productData = await fetchMedusaApi<any>({
  endpoint: `store/products/custom/${id}`,
});
---

<Layout
  title="Curtain Customization | Blindzy Australia"
  description="Customize your curtains with Blindzy Australia's easy-to-use customization tool. Choose from a variety of styles, colors, and materials to create the perfect curtains for your home. Our custom DIY curtains are designed for easy installation and long-lasting beauty. Start customizing your curtains today and transform your windows with Blindzy Australia."
>
  <Navbar client:load logo={"dark"} />
  {
    productData?.product ? (
      <Single_curtain_customization
        data={productData.product}
        groupData={groupData}
        client:load
      />
    ) : (
      <p class="text-center text-red-500">Product not found.</p>
    )
  }
  <!-- <Single_curtain_customization client:load data={sampleProducts[0]} type={'Curtains'} /> -->
  <Footer client:load category_button={false} />
</Layout>
