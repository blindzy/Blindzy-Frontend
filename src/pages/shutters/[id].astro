---
import Layout from "@layouts/Layout.astro";
import Navbar from "@components/navbar/navbar";
import Footer from "@components/Footer/Footer";
import Shutters_customization from "@components/customization/shutters-customization";
import fetchMedusaApi from "@lib/lib/fetchMedusaApi";
import fetchApi from "@lib/strapi";
import type { GroupData } from "@interfaces/interfaces";

async function getData() {
  const groupData = await fetchApi<GroupData>({
    endpoint: "shutter-price?populate=*",
    wrappedByKey: "data",
  });
  return { groupData };
}
const { groupData } = await getData();

export async function getStaticPaths() {
  // First get list of all products to get their IDs
  const allProducts = await fetchMedusaApi<any>({
    endpoint: "store/products/custom",
  });
  // Return array of objects with id params for all products
  return (allProducts?.products || []).map((product: any) => ({
    params: { id: product.id },
  }));
}

const { id } = Astro.params;

// Fetch full product data at render time
const productData = await fetchMedusaApi<any>({
  endpoint: `store/products/custom/${id}`,
});
---

<Layout>
  <Navbar client:load logo={"dark"} />
  {
    productData?.product && (
      <Shutters_customization
        data={productData.product}
        groupData={groupData}
        client:load
      />
    )
  }
  <Footer client:load />
</Layout>
