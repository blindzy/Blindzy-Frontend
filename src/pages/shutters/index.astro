---
import Layout from "@layouts/Layout.astro";
import Navbar from "@components/navbar/navbar";
import InnerBanner from "@components/inner-banner/innerBanner";
import ShopComponent from "@components/shop/Shop";
import Footer from "@components/Footer/Footer";
import fetchMedusaApi from "@lib/lib/fetchMedusaApi";
import fetchApi from "@lib/strapi";
import type { GroupData } from "@interfaces/interfaces";

async function getData() {
  const groupData = await fetchApi<GroupData>({
    endpoint: "shutter-price?populate=*",
    wrappedByKey: "data",
  });
  return { groupData };
}
const { groupData } = await getData();

const productsData = await fetchMedusaApi<any>({
  endpoint: "/store/products/custom",
});

const filteredProducts = (productsData?.products || []).filter((product) => {
  const hasBlindsCategory = product.categories?.some(
    (cat) => cat.name?.toLowerCase() === "shutters",
  );

  return hasBlindsCategory;
});
const tags = [
  // 'Blockout',
  // 'Light Filtering',
  // 'Sunscreen',
];
---

<Layout>
  <Navbar client:load logo="dark" />
  <InnerBanner
    client:load
    title="Shutters SHOP"
    content="Beautiful Designer shutters You Can Install in 20 Minutes"
  />
  <ShopComponent
    client:load
    data={filteredProducts}
    customizePage="shutters"
    tags={tags}
    type=""
    groupData={groupData}
  />
  <Footer client:visible />
</Layout>

