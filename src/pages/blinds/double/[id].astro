---
import Layout from "@layouts/Layout.astro";
import Navbar from "@components/navbar/navbar";
import Footer from "@components/Footer/Footer";
import Double_blind_customization from "@components/customization/double-blind-customization";
import fetchMedusaApi from "@lib/lib/fetchMedusaApi";
import fetchApi from "@lib/strapi";
import type { GroupData } from "@interfaces/interfaces";

async function getData() {
  const groupData = await fetchApi<GroupData>({
    endpoint: "blind-price?populate=*",
    wrappedByKey: "data",
  });
  return { groupData };
}
const { groupData } = await getData();

export async function getStaticPaths() {
  // First get list of all products to get their IDs
  const allProducts = await fetchMedusaApi<any>({
    endpoint: "store/products/custom",
  });
  // Return array of objects with id params for all products
  return (allProducts?.products || []).map((product: any) => ({
    params: { id: product.id },
  }));
}

const { id } = Astro.params;

// Fetch full product data at render time
const productData = await fetchMedusaApi<any>({
  endpoint: `store/products/custom/${id}`,
});
---

<Layout
  title="Double Roller Blinds Customization | Blindzy Australia"
  description="Customize your double roller blinds with Blindzy Australia's easy-to-use customization tool. Choose from a variety of styles, colors, and materials to create the perfect double roller blinds for your home. Our custom DIY double roller blinds are designed for easy installation and long-lasting beauty. Start customizing your double roller blinds today and transform your windows with Blindzy Australia."
>
  <Navbar client:load logo={"dark"} />
  <Double_blind_customization
    client:load
    data={productData.product}
    groupData={groupData}
  />
  <Footer client:load category_button={false} />
</Layout>
